# Production Environment Variables Template
# Copy this file to .env and fill in your actual values

# Database Configuration (NEW format - recommended)
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost  # or your-remote-postgres-host.com or IP address
DATABASE_PORT=5432
DATABASE_NAME=kidchatboxdb
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false  # Set to 'true' for remote connections with SSL

# Database Configuration (LEGACY format - still supported for backward compatibility)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=kidchatbox
# DB_USER=postgres
# DB_PASSWORD=your_password
 
# Server Configuration
PORT=3001
NODE_ENV=production

# Security - Generate a random 32+ character string
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your-production-jwt-secret-minimum-32-characters-long

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-your-openai-api-key-here

# Frontend Configuration
# Use your canonical site URL (both www and non-www are allowed automatically)
VITE_FRONTEND_URL=https://guru-ai.cloud
VITE_API_BASE_URL=https://guru-ai.cloud/api
# Optional extra CORS origins (comma-separated), e.g. https://app.otherdomain.com
# CORS_ORIGINS=

# Google OAuth (Optional)
# Get from: https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# SMTP Email Configuration
# Used for sending welcome emails and notifications
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@greenwoodscity.in
SMTP_PASSWORD=Greenwood@122003

